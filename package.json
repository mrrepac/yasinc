{
  "name": "yasinc",
  "version": "0.3.4",
  "type": "module",
  "description": "Obsidian plugin: two-way vault synchronization with Yandex Disk.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian-plugin",
    "sync",
    "yandex-disk",
    "yandex",
    "backup"
  ],
  "author": "mrrepac",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "4.7.4"
  },
  "allowScripts": {
    "esbuild@0.17.3": true
  }
}
